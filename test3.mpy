from machine import Pin
from utime import sleep_ms

sensor = Pin(4, Pin.IN)

last_state = 0

while True:
    current = sensor.value()

    # Detect only change (edge detection)
    if current == 1 and last_state == 0:
        print("Vibration detected!")

    elif current == 0 and last_state == 1:
        print("Stopped")

    last_state = current
    sleep_ms(50)