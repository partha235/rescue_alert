from machine import Pin, SPI
import ssd1306
import time

# ---------------- OLED SETUP (SPI) ----------------
spi = SPI(1, baudrate=10000000, polarity=0, phase=0,
          sck=Pin(18), mosi=Pin(22))

dc  = Pin(16)
res = Pin(17)
cs  = Pin(5)

oled = ssd1306.SSD1306_SPI(128, 64, spi, dc, res, cs)

# ---------------- ENCODER SETUP ----------------
clk = Pin(25, Pin.IN)
dt  = Pin(26, Pin.IN )
sw  = Pin(27, Pin.IN )

counter = 0
last_clk = clk.value()
oled.fill(0)
oled.text("Counter:", 10, 20)
oled.show()

# ---------------- FUNCTIONS ----------------
def update_display():
    oled.fill(0)
    oled.text("Counter:", 10, 20)
    oled.text(str(counter), 10, 40)
    oled.show()

def read_encoder():
    global counter, last_clk
    
    current_clk = clk.value()

    # Count only on FALLING edge
    if last_clk == 1 and current_clk == 0:
        if dt.value() == 1:
            counter += 1
        else:
            counter -= 1
        
        update_display()

    last_clk = current_clk

def check_button():
    global counter
    if sw.value() == 0:
        counter = 0
        update_display()
        time.sleep_ms(300)

# ---------------- MAIN LOOP ----------------
update_display()

while True:
    read_encoder()
    check_button()
    time.sleep_ms(2)