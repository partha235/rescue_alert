# credential file import
try:
    from bps_cre import *     
except:
    pass

try:
    import urequests as requests
except:
    import requests

from machine import Pin, SPI
from utime import sleep_ms, time
import network
import ssd1306
import gc

gc.collect()

# ---------------- CONFIG ----------------
SSID = "iPhone"
PASSWORD = "12345678"

recipient_num = "+917904333043"
sender_num = "+12183221077"
auth_token = "b8a59ff4a8377aafccdb990d3f890a34"
account_sid = "AC367c0640459695746cb179da43cbb8f0"

latitude = 11.3901778
longitude = 79.7037785

# ---------------- PINS ----------------
sensor = Pin(4, Pin.IN)                    # vibration
button = Pin(15, Pin.IN, Pin.PULL_UP)      # button

# Encoder
clk = Pin(25, Pin.IN, Pin.PULL_UP)
dt  = Pin(26, Pin.IN, Pin.PULL_UP)
sw  = Pin(27, Pin.IN, Pin.PULL_UP)

# ---------------- OLED (SPI) ----------------
spi = SPI(1, baudrate=10000000, polarity=0, phase=0,
          sck=Pin(18), mosi=Pin(22))   # correct MOSI

dc  = Pin(16)
res = Pin(17)
cs  = Pin(5)

oled = ssd1306.SSD1306_SPI(128, 64, spi, dc, res, cs)

# ---------------- GLOBALS ----------------
counter = 0
last_clk = clk.value()

status_msg = "Idle"

last_sent_time = 0
cooldown = 10  # seconds

last_vibration = 0
last_button = 1

# ---------------- WIFI ----------------
def connect_wifi():
    sta = network.WLAN(network.STA_IF)
    sta.active(True)
    print(sta.scan())

    if not sta.isconnected():
        print("Connecting WiFi...")
        sta.connect(SSID, PASSWORD)

        while not sta.isconnected():
            sleep_ms(500)

    print("Connected:", sta.ifconfig())

# ---------------- DISPLAY ----------------
def update_display():
    oled.fill(0)
    oled.text("Counter:", 0, 10)
    oled.text(str(counter), 0, 25)

    oled.text("Status:", 0, 45)
    oled.text(status_msg, 60, 45)

    oled.show()

# ---------------- ENCODER ----------------
def read_encoder():
    global counter, last_clk, status_msg

    current_clk = clk.value()

    if last_clk == 1 and current_clk == 0:
        if dt.value() == 1:
            counter += 1
        else:
            counter -= 1

        status_msg = "Rotating"
        update_display()

    last_clk = current_clk

# ---------------- SMS ----------------
def send_sms(message):
    global last_sent_time, status_msg

    if time() - last_sent_time < cooldown:
        print("Cooldown active")
        status_msg = "Cooldown"
        update_display()
        return

    url = "https://api.twilio.com/2010-04-01/Accounts/{}/Messages.json".format(account_sid)

    data = "To={}&From={}&Body={}".format(recipient_num, sender_num, message)

    try:
        res = requests.post(
            url,
            data=data,
            auth=(account_sid, auth_token),
            headers={'Content-Type': 'application/x-www-form-urlencoded'}
        )

        print("Status:", res.status_code)

        if res.status_code == 201:
            print("SMS sent ✅")
            status_msg = "SMS Sent"
            last_sent_time = time()
        else:
            print("Error:", res.text)
            status_msg = "SMS Error"

        res.close()

    except Exception as e:
        print("Failed:", e)
        status_msg = "Net Error"

    update_display()

# ---------------- MAIN ----------------
def main():
    global last_vibration, last_button, status_msg

    connect_wifi()
    update_display()

    while True:
        read_encoder()

        vibration = sensor.value()
        print(" vibration= ", vibration)
        btn = button.value()

        link = "https://maps.google.com/?q={},{}".format(latitude, longitude)

        # -------- VIBRATION ALERT --------
        if vibration == 1 and last_vibration == 0:
            print("Vibration detected!")

            status_msg = "Vibration!"
            update_display()

            msg = "⚠ Vibration Alert!\nCount: {}\n{}".format(counter, link)
            send_sms(msg)

        # -------- BUTTON ALERT --------
        if btn == 0 and last_button == 1:
            print("Button pressed!")

            status_msg = "Button Press"
            update_display()

            msg = "📍 Manual Alert\nCount: {}\n{}".format(counter, link)
            send_sms(msg)

        # -------- IDLE STATE --------
        if vibration == 0 and btn == 1:
            status_msg = "Idle"

        last_vibration = vibration
        last_button = btn

        sleep_ms(20)

# ---------------- START ----------------
if __name__ == "__main__":
    main()