from machine import Pin
import time

# Pin setup
clk = Pin(18, Pin.IN, Pin.PULL_UP)
dt  = Pin(19, Pin.IN, Pin.PULL_UP)
sw  = Pin(21, Pin.IN, Pin.PULL_UP)

counter = 0
last_clk = clk.value()

def read_encoder():
    global counter, last_clk
    
    current_clk = clk.value()
    
    if current_clk != last_clk:
        # Detect direction
        if dt.value() != current_clk:
            counter += 1
        else:
            counter -= 1
        
        print("Counter:", counter)
    
    last_clk = current_clk

def check_button():
    if sw.value() == 0:   # pressed
        print("Button Pressed")
        time.sleep_ms(300)  # debounce

# Main loop
while True:
    read_encoder()
    check_button()
    time.sleep_ms(2)