try:
    import urequests as requests
except:
    import requests

from machine import Pin, ADC, UART
from utime import sleep, sleep_ms, time
import network
import gc
try:
    from bps_cre import *     
except:
    pass
import ssd1306
import time

gc.collect()

latitude = 11.3901778
longitude = 79.7037785

sensor = Pin(4, Pin.IN)
button =Pin(15,Pin.IN,Pin.PULL_UP)

# ---------------- OLED SETUP (SPI) ----------------
spi = SPI(1, baudrate=10000000, polarity=0, phase=0,
          sck=Pin(18), mosi=Pin(22))

dc  = Pin(16)
res = Pin(17)
cs  = Pin(5)

oled = ssd1306.SSD1306_SPI(128, 64, spi, dc, res, cs)

# ---------------- ENCODER SETUP ----------------
clk = Pin(25, Pin.IN)
dt  = Pin(26, Pin.IN )
sw  = Pin(27, Pin.IN )

counter = 0
last_clk = clk.value()
oled.fill(0)
oled.text("Counter:", 10, 20)
oled.show()
SSID = bps_ssid
PASSWORD = ssid_pas

recipient_num = twilio_rnum
sender_num = twilio_snum
auth_token = twilio_tok
account_sid = twilio_sid



# ---------------- WIFI ----------------
def connect_wifi():
    station = network.WLAN(network.STA_IF)
    station.active(True)

    if not station.isconnected():
        print("Connecting...")
        station.connect(SSID, PASSWORD)

        for _ in range(10):
            if station.isconnected():
                break
            sleep(1)

    print("WiFi:", station.ifconfig())


# ---------------- FUNCTIONS ----------------
def update_display():
    oled.fill(0)
    oled.text("Counter:", 10, 20)
    oled.text(str(counter), 10, 40)
    oled.show()

def read_encoder():
    global counter, last_clk
    
    current_clk = clk.value()

    # Count only on FALLING edge
    if last_clk == 1 and current_clk == 0:
        if dt.value() == 1:
            counter += 1
        else:
            counter -= 1
        
        update_display()

    last_clk = current_clk

def check_button():
    global counter
    if sw.value() == 0:
        counter = 0
        update_display()
        time.sleep_ms(300)

# ---------------- MAIN LOOP ----------------
update_display()

# ---------------- SMS ----------------
def send_sms(message):
    global last_sent_time

    if time() - last_sent_time < cooldown:
        print("Cooldown active")
        return

    url = "https://api.twilio.com/2010-04-01/Accounts/{}/Messages.json".format(account_sid)

    message = message.replace(" ", "%20")

    data = "To={}&From={}&Body={}".format(recipient_num, sender_num, message)

    try:
        res = requests.post(
            url,
            data=data,
            auth=(account_sid, auth_token),
            headers={'Content-Type': 'application/x-www-form-urlencoded'}
        )

        print("Status:", res.status_code)

        if res.status_code == 201:
            print("SMS sent ✅")
            last_sent_time = time()
        else:
            print("Error:", res.text)

        res.close()

    except Exception as e:
        print("Failed:", e)


# ---------------- MAIN ----------------
def main():
    connect_wifi()

    while True:

        gps_ok = getGPS(gpsModule)

        if not gps_ok:
            print("No GPS data. Using fallback location.")
            latitude = str(DEFAULT_LATITUDE)
            longitude = str(DEFAULT_LONGITUDE)

        link = "https://maps.google.com/?q={},{}".format(latitude, longitude)

        if not fs.value():
            send_sms("🔥 Fire detected! " + link)
 
        elif ss.read() > threshold:
            send_sms("⚠ Gas Leak! " + link)

        elif not but.value():
            send_sms("📍 Manual Location: " + link)

        else:
            print("Latitude:", latitude)
            print("Longitude:", longitude)
            print("Satellites:", satellites)
            print("Time:", GPStime)
            print("----------------------")

        sleep(2)


# ---------------- START ----------------
if __name__ == "__main__":
    main()